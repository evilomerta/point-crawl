# Copy this file to .env.local for local dev, and set the same keys in Vercel.
# Firebase web config keys are NOT secret. They are meant to live in client code.
# The real access control is your Firestore rules + the site password below.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123

# Shared password every player types to enter the site (minimum defense).
VITE_SITE_PASSWORD=changeme

# Extra password only YOU type to take the DM seat.
VITE_DM_PASSWORD=dmsecret
